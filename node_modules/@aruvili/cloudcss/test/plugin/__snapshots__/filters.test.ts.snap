// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`filter plugin > add completions > completions 1`] = `
{
  "backdropFilter": [
    "backdrop-{static}",
  ],
  "blur": [
    "blur-{static}",
  ],
  "filter": [
    "blur-{static}",
  ],
}
`;

exports[`filter plugin > interpret test > css 1`] = `
".filter-none {
  -webkit-filter: none;
  filter: none;
}
.hover\\:filter-none:hover {
  -webkit-filter: none;
  filter: none;
}
.filter-grayscale {
  -webkit-filter: grayscale(1);
  filter: grayscale(1);
}
.hover\\:filter-grayscale:hover {
  -webkit-filter: grayscale(1);
  filter: grayscale(1);
}
.backdrop-none {
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}
.backdrop-blur {
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
}
@media (min-width: 640px) {
  .sm\\:filter-none {
    -webkit-filter: none;
    filter: none;
  }
  .sm\\:filter-grayscale {
    -webkit-filter: grayscale(1);
    filter: grayscale(1);
  }
}"
`;
