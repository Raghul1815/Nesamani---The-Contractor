{
  "name": "@aruvili/cloudcss",
  "version": "1.0.1",
  "packageManager": "pnpm@10.32.1",
  "description": "cloudCSS - The revived next generation utility-first CSS framework.",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "bin": {
    "cloudcss": "dist/cli/index.cjs",
    "cloud": "dist/cli/index.cjs"
  },
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "build:prod": "cross-env NODE_ENV=production rollup -c",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "coverage": "vitest run --coverage",
    "tsd": "tsd",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./colors": {
      "import": "./colors.mjs",
      "require": "./colors.js"
    },
    "./defaultConfig": {
      "import": "./defaultConfig.mjs",
      "require": "./defaultConfig.js"
    },
    "./defaultTheme": {
      "import": "./defaultTheme.mjs",
      "require": "./defaultTheme.js"
    },
    "./config": {
      "import": "./config/index.mjs",
      "require": "./config/index.js"
    },
    "./lib": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js"
    },
    "./plugin": {
      "import": "./plugin/index.mjs",
      "require": "./plugin/index.js"
    },
    "./plugin/aspect-ratio": {
      "import": "./plugin/aspect-ratio/index.js",
      "require": "./plugin/aspect-ratio/index.js"
    },
    "./plugin/filters": {
      "import": "./plugin/filters/index.js",
      "require": "./plugin/filters/index.js"
    },
    "./plugin/forms": {
      "import": "./plugin/forms/index.js",
      "require": "./plugin/forms/index.js"
    },
    "./plugin/line-clamp": {
      "import": "./plugin/line-clamp/index.js",
      "require": "./plugin/line-clamp/index.js"
    },
    "./plugin/typography": {
      "import": "./plugin/typography/index.js",
      "require": "./plugin/typography/index.js"
    },
    "./plugin/scroll-snap": {
      "import": "./plugin/scroll-snap/index.js",
      "require": "./plugin/scroll-snap/index.js"
    },
    "./helpers": {
      "import": "./dist/helpers/index.mjs",
      "require": "./dist/helpers/index.js"
    },
    "./utils": {
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.js"
    },
    "./utils/parser": {
      "import": "./dist/utils/parser/index.mjs",
      "require": "./dist/utils/parser/index.js"
    },
    "./utils/style": {
      "import": "./dist/utils/style/index.mjs",
      "require": "./dist/utils/style/index.js"
    },
    "./postcss": {
      "import": "./postcss.cjs",
      "require": "./postcss.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aruvili/cloudcss.git"
  },
  "keywords": [
    "cloudcss",
    "windicss",
    "tailwindcss",
    "css",
    "compiler"
  ],
  "engines": {
    "node": ">= 18"
  },
  "author": "Aruvili",
  "license": "MIT",
  "homepage": "https://github.com/Aruvili/cloudcss",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/color-string": "^1.5.5",
    "@types/diff": "^8.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^1.6.0",
    "arg": "^5.0.2",
    "bumpp": "^11.0.0",
    "caller-path": "^4.0.0",
    "color-string": "^2.1.4",
    "cross-env": "^10.1.0",
    "diff": "^8.0.3",
    "domhandler": "^5.0.3",
    "eslint": "^10.0.3",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "js-yaml": "^4.1.1",
    "mini-svg-data-uri": "^1.4.4",
    "minimatch": "^10.2.4",
    "nyc": "^18.0.0",
    "picocolors": "^1.1.1",
    "postcss": "^8.4.38",
    "rollup": "^4.59.0",
    "sucrase": "^3.35.1",
    "tosource": "^2.0.0-alpha.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
